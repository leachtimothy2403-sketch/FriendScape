{
  "expo": {
    "name": "Migo",
    "slug": "migo",
    "version": "1.0.0",
    "scheme": "migo",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "icon": "./assets/images/migo-logo.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/migo-logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#F8F7FF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.migo.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/migo-logo.jpg",
        "backgroundColor": "#F8F7FF"
      },
      "package": "com.migo.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Migo uses your photo library to let you share pictures with your friends."
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
