{
  "expo": {
    "name": "Migo",
    "slug": "migo",
    "version": "1.0.0",
    "scheme": "migo",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "icon": "./assets/images/migo-logo.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/migo-logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#F8F7FF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.migo.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/migo-logo.jpg",
        "backgroundColor": "#F8F7FF"
      },
      "package": "com.migo.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Migo uses your photo library to let you share pictures with your friends."
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ab879822-9ae4-41ce-8898-b5bf0ce58945"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ab879822-9ae4-41ce-8898-b5bf0ce58945"
    }
  }
}
