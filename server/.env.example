PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/friendscape

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_REFRESH_SECRET=another_long_random_string_for_refresh_tokens

# App Store / Play Store reviewer 2FA bypass (leave unset in normal dev/prod —
# only needed on whichever environment the review builds point at)
REVIEWER_BYPASS_EMAIL=
REVIEWER_BYPASS_OTP_CODE=

# Anthropic (AI friends)
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs (text-to-speech for AI voice messages)
ELEVENLABS_API_KEY=...

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@friendscape.app
SMTP_PASS=your_smtp_password

# Frontend URLs (for CORS + email links)
FRONTEND_URL=http://localhost:8081
PARENT_DASHBOARD_URL=http://localhost:3000
