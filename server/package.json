{
  "name": "migo-server",
  "version": "1.0.0",
  "description": "Migo API server",
  "main": "dist/index.js",
  "scripts": {
    "test": "jest --config jest.config.ts --runInBand --forceExit",
    "dev": "node -e \"const {execSync} = require('child_process'); try { const pid = execSync('netstat -ano | findstr :3001').toString().match(/LISTENING\\s+(\\d+)/)?.[1]; if (pid) { execSync('taskkill /F /PID ' + pid); console.log('[dev] Killed stale process on port 3001'); } } catch(e) {} \" && nodemon --watch src --ext ts,json --exec \"ts-node -r dotenv/config src/index.ts\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "npx knex --knexfile src/db/knexfile.ts migrate:latest",
    "migrate:rollback": "npx knex --knexfile src/db/knexfile.ts migrate:rollback",
    "migrate:make": "npx knex --knexfile src/db/knexfile.ts migrate:make",
    "seed": "npx knex --knexfile src/db/knexfile.ts seed:run",
    "db:check": "ts-node -r dotenv/config scripts/check-db.ts",
    "beta:metrics": "ts-node -r dotenv/config scripts/betaMetrics.ts",
    "generate:audio": "ts-node -r dotenv/config scripts/generateMigaAudio.ts",
    "demo:generate": "ts-node -r dotenv/config scripts/generateDemoFriends.ts",
    "avatars:star-friends": "ts-node scripts/generateStarFriendAvatars.ts",
    "avatars:network-friends": "ts-node scripts/generateNetworkFriendAvatars.ts",
    "avatars:luna": "ts-node scripts/generateLunaAvatar.ts",
    "audio:pregenerate": "ts-node scripts/pregenerateStaticAudio.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@fal-ai/client": "^1.10.1",
    "@google/genai": "^2.10.0",
    "@types/node-cron": "^3.0.11",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "elevenlabs": "^1.59.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.14",
    "pg": "^8.12.0",
    "uuid": "^10.0.0",
    "wav": "^1.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/wav": "^1.0.4",
    "jest": "^30.4.2",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
